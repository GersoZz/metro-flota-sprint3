generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


enum VehicleType {
  BusArticulado @map("Bus Articulado")
  Alimentador
}

enum VehicleState {
  Operativo
  EnTaller     @map("En Taller")
  Alerta
  DadoDeBaja   @map("Dado de Baja")
}

// Tipo de combustible del vehiculo (RF-01).
enum FuelType {
  Diesel
  GNV
  Electrico @map("Eléctrico")
}

// Tipo de dia para las franjas de frecuencia (RF-07).
enum DayType {
  Laborable
  Sabado    @map("Sábado")
  Domingo
}

// Franja horaria de una frecuencia (RF-07).
enum TimeBand {
  PicoManana @map("Pico Mañana")
  PicoTarde  @map("Pico Tarde")
  Valle
  Baja
}

enum RouteType {
  Troncal
  Expreso
  Alimentador
}

enum RouteState {
  Activa
  EnRevision @map("En Revisión")
  Suspendida
}

enum AlertTone {
  danger
  warning
}

enum UserRole {
  admin
  operador
  supervisor
  planificador
  jefe_mantenimiento
  directivo
}

enum MaintenanceType {
  Preventivo
  Correctivo
}

enum MaintenanceStatus {
  Programado
  EnCurso    @map("En Curso")
  Completado
}

model Consortium {
  id       String    @id @default(uuid())
  name     String    @unique
  vehicles Vehicle[]

  @@map("consortiums")
}

model Vehicle {
  id                 String       @id
  plate              String       @unique
  type               VehicleType
  km                 Int          @default(0)
  state              VehicleState @default(Operativo)
  lastInspectionDate DateTime     @db.Date

  // Datos adicionales de la unidad (RF-01).
  capacity Int?
  year     Int?
  fuelType FuelType?

  consortiumId String
  consortium   Consortium @relation(fields: [consortiumId], references: [id])

  currentRouteCode String?
  currentRoute     Route?  @relation("VehicleCurrentRoute", fields: [currentRouteCode], references: [code])

  statuses     VehicleStatus[]
  alerts       Alert[]
  maintenances Maintenance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([state])
  @@index([consortiumId])
  @@map("vehicles")
}

model Route {
  code             String     @id
  name             String
  type             RouteType
  lengthKm         Decimal    @db.Decimal(6, 2)
  frequencyMinutes Int
  busesAssigned    Int        @default(0)
  state            RouteState @default(Activa)
  imageUrl         String?

  stops          Stop[]
  vehicles       Vehicle[]        @relation("VehicleCurrentRoute")
  alerts         Alert[]
  frequencyBands FrequencyBand[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([state])
  @@index([type])
  @@map("routes")
}

// Frecuencia de una ruta segun tipo de dia y franja horaria (RF-07).
// Route.frequencyMinutes se conserva por compatibilidad.
model FrequencyBand {
  id              String   @id @default(uuid())
  dayType         DayType
  timeBand        TimeBand
  intervalMinutes Int

  routeCode String
  route     Route  @relation(fields: [routeCode], references: [code], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([routeCode, dayType, timeBand])
  @@index([routeCode])
  @@map("frequency_bands")
}

model Stop {
  id    String   @id @default(uuid())
  name  String
  order Int
  lat   Decimal? @db.Decimal(9, 6)
  lng   Decimal? @db.Decimal(9, 6)

  routeCode String
  route     Route  @relation(fields: [routeCode], references: [code], onDelete: Cascade)

  nextForStatuses VehicleStatus[] @relation("NextStop")

  @@unique([routeCode, order])
  @@index([routeCode])
  @@map("stops")
}

model Driver {
  id            String @id @default(uuid())
  name          String
  licenseNumber String @unique
  statuses VehicleStatus[]

  createdAt DateTime @default(now())

  @@map("drivers")
}

model VehicleStatus {
  id         String   @id @default(uuid())
  speedKmh   Int
  passengers Int
  capacity   Int
  lat        Decimal  @db.Decimal(9, 6)
  lng        Decimal  @db.Decimal(9, 6)
  recordedAt DateTime @default(now())

  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  driverId String?
  driver   Driver? @relation(fields: [driverId], references: [id])

  nextStopId String?
  nextStop   Stop?   @relation("NextStop", fields: [nextStopId], references: [id])

  @@index([vehicleId, recordedAt(sort: Desc)])
  @@map("vehicle_statuses")
}

model Alert {
  id    String    @id @default(uuid())
  title String
  text  String
  tone  AlertTone

  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])

  routeCode String?
  route     Route?  @relation(fields: [routeCode], references: [code])

  createdAt      DateTime  @default(now())
  acknowledgedAt DateTime?

  @@index([tone])
  @@index([acknowledgedAt])
  @@index([createdAt(sort: Desc)])
  @@map("alerts")
}

// Orden de mantenimiento de un vehiculo (modulo M4 del SRS, RF-17 a RF-21).
model Maintenance {
  id          String            @id @default(uuid())
  type        MaintenanceType
  status      MaintenanceStatus @default(Programado)
  description String

  // Umbral del mantenimiento preventivo: se programa por kilometraje o por fecha.
  thresholdKm   Int?
  scheduledDate DateTime? @db.Date

  // Datos que se llenan cuando el mantenimiento se ejecuta (RF-19).
  executedDate DateTime? @db.Date
  components   String?
  costEstimate Decimal?  @db.Decimal(10, 2)
  hours        Decimal?  @db.Decimal(6, 2)
  technician   String?

  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vehicleId, createdAt(sort: Desc)])
  @@index([status])
  @@map("maintenances")
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(operador)

  auditLogs AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// Registro de auditoria de operaciones de escritura (RF-29).
// El middleware que lo llena lo agrega otro modulo; aca solo el modelo.
model AuditLog {
  id       String @id @default(uuid())
  action   String
  entity   String
  entityId String?
  detail   String?

  userId String?
  user   User?  @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}
